amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"

local checks = new Mapping<String, Step> {
  ["gitleaks"] {
    check = "gitleaks dir --redact --verbose --no-banner ."
    exclusive = true
  }
  ["treefmt"] {
    check = "treefmt --fail-on-change"
    exclusive = true
  }
}

hooks {
  ["pre-commit"] {
    stash = "git"
    steps = checks
  }
  ["check"] {
    steps = checks
  }
}
