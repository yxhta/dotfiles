#!/bin/sh
#
# Herdr Agent Picker
# List only Herdr-detected agent panes, preview the selected pane, and jump to it.
# Dependencies: herdr, jq, fzf

set -eu

# Same key-wait pattern as bin/ai-session-selector: this script runs in a
# self-closing floating pane, so hold the message until Enter/Esc/q.
wait_for_keypress() {
  tty_state=$(stty -g </dev/tty 2>/dev/null || true)
  if [ -n "$tty_state" ]; then
    stty -echo -icanon min 1 time 0 </dev/tty 2>/dev/null || true
    trap 'stty "$tty_state" < /dev/tty 2>/dev/null || true; exit 130' INT TERM

    while :; do
      key_code=$(dd bs=1 count=1 2>/dev/null </dev/tty | od -An -t u1 | tr -d '[:space:]')

      case "$key_code" in
        10 | 13 | 27 | 81 | 113) break ;;
      esac
    done

    trap - INT TERM
    stty "$tty_state" </dev/tty 2>/dev/null || true
  else
    read -r _
  fi
}

in_interactive_popup() {
  [ -n "${TMUX:-}" ] && [ -t 0 ] && [ -t 1 ]
}

die() {
  message=$1

  echo "herdr-agent-picker: ${message}" >&2
  if in_interactive_popup; then
    wait_for_keypress
  fi
  exit 1
}

show_empty_state_and_exit() {
  message=$1

  if in_interactive_popup; then
    printf '%s' "$message"
    wait_for_keypress
    exit 0
  fi

  echo "$message" >&2
  exit 1
}

require_command() {
  command_name=$1

  if ! command -v "$command_name" >/dev/null 2>&1; then
    die "missing required command: ${command_name}"
  fi
}

for command_name in herdr jq fzf; do
  require_command "$command_name"
done

jq_filter='
  def dash:
    if . == null or . == "" then "-" else tostring end;

  def location:
    [.workspace_id, .tab_id, .pane_id | select(. != null and . != "")]
    | if length == 0 then "-" else join("/") end;

  def short_cwd:
    (.cwd? | dash) as $cwd
    | (env.HOME // "") as $home
    | if $cwd == "-" then "-"
      elif $home != "" and $cwd == $home then "~"
      elif $home != "" and ($cwd | startswith($home + "/")) then "~/" + ($cwd | ltrimstr($home + "/"))
      else $cwd
      end;

  .result.agents // []
  | .[]
  # herdr accepts either id as a focus/read target; prefer terminal_id
  | first((.terminal_id, .pane_id) | select(. != null and . != "")) as $target
  | [
      $target,
      (.agent? | dash),
      (.agent_status? | dash),
      location,
      short_cwd
    ]
  | @tsv
'

if ! agent_json=$(herdr agent list); then
  die "failed to list Herdr agents"
fi

if ! agent_records=$(printf '%s\n' "$agent_json" | jq -r "$jq_filter"); then
  die "failed to parse Herdr agent list"
fi

if [ -z "$agent_records" ]; then
  show_empty_state_and_exit "No Herdr agent panes found"
fi

set +e
selection=$(printf '%s\n' "$agent_records" | fzf \
  --ansi \
  --select-1 \
  --prompt="Agent: " \
  --header="AGENT	STATUS	LOCATION	DIRECTORY" \
  --delimiter='	' \
  --with-nth='2..' \
  --preview='herdr agent read {1} --source visible --format ansi 2>/dev/null | jq -er ".result.read.text // empty" || printf "Preview unavailable: %s\n" {1}' \
  --preview-window="right:60%:wrap")
fzf_status=$?
set -e

case "$fzf_status" in
  0) ;;
  1 | 130) exit 0 ;;
  *) exit "$fzf_status" ;;
esac

tab=$(printf '\t')
terminal_id=${selection%%"$tab"*}

if ! herdr agent focus "$terminal_id"; then
  die "failed to focus Herdr agent pane: ${terminal_id}"
fi
