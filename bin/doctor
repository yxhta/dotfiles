#!/bin/sh
set -eu

warn_count=0
fail_count=0

OK() { printf '\033[32m[OK]\033[0m   %s\n' "$1"; }
WARN() {
  printf '\033[33m[WARN]\033[0m %s\n' "$1"
  warn_count=$((warn_count + 1))
}
FAIL() {
  printf '\033[31m[FAIL]\033[0m %s\n' "$1"
  fail_count=$((fail_count + 1))
}

if command -v mise >/dev/null 2>&1; then
  mise_path=$(command -v mise)
  OK "mise on PATH ($mise_path)"
  case "$mise_path" in
    "$HOME/.local/bin/mise" | "$HOME/bin/mise") ;;
    *) WARN "mise is outside the bootstrap-managed paths: $mise_path" ;;
  esac
else
  FAIL "mise not found — run: ./bin/mise --version; then restart the shell"
fi

if printf '%s\n' "$PATH" | tr ':' '\n' | grep -Fx "$HOME/.local/bin" >/dev/null 2>&1; then
  OK "$HOME/.local/bin is on PATH"
else
  FAIL "$HOME/.local/bin missing from PATH — apply ~/.zshenv and restart the shell"
fi

if [ -f "$HOME/.gitconfig_private" ]; then
  OK "~/.gitconfig_private present"
else
  WARN "~/.gitconfig_private missing — git identity falls through"
fi

sheldon_repos="$HOME/.local/share/sheldon/repos"
if [ -d "$sheldon_repos" ] && [ -n "$(ls -A "$sheldon_repos" 2>/dev/null)" ]; then
  OK "sheldon plugins cloned"
else
  WARN "sheldon repos not cloned — run: sheldon lock --update"
fi

if command -v mise >/dev/null 2>&1; then
  if mise config ls >/dev/null 2>&1; then
    OK "mise configuration loads"
  else
    FAIL "mise configuration failed to load — run: mise config ls"
  fi
  if mise bootstrap status --missing >/dev/null 2>&1; then
    OK "mise bootstrap state converged"
  else
    WARN "mise bootstrap has missing/drifted entries — run: mise bootstrap status"
  fi
fi

if git_top=$(git rev-parse --show-toplevel 2>/dev/null); then
  # hk installs hooks as git config entries (git 2.51+), not .git/hooks files
  if git -C "$git_top" config get hook.hk-pre-commit.command >/dev/null 2>&1 ||
    [ -x "$git_top/.git/hooks/pre-commit" ]; then
    OK "hk pre-commit hook installed"
  else
    WARN "hk pre-commit hook missing — run: hk install --mise"
  fi
fi

printf '\n'
if [ "$fail_count" -gt 0 ]; then
  printf '%d failed, %d warnings\n' "$fail_count" "$warn_count" >&2
  exit 1
elif [ "$warn_count" -gt 0 ]; then
  printf '%d warnings\n' "$warn_count"
else
  printf 'all checks passed\n'
fi
